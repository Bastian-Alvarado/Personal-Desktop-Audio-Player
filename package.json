{
  "name": "simonrelays-player",
  "version": "1.0.0",
  "description": "SimonRelays Desktop Audio Player",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "npx -y concurrently \"npx -y http-server . -p 3000\" \"npx -y wait-on http://localhost:3000 && electron .\"",
    "dist": "electron-builder --win"
  },
  "keywords": [],
  "author": "SimonRelays",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.simonrelays.player",
    "productName": "SimonRelays Player",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "firebase.js",
      "manifest.json",
      "service-worker.js",
      "icon.png",
      "icon-192.png",
      "icon-512.png",
      "icon.svg",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!**/*.map",
      "!test-*.js",
      "!*.log",
      "!*.txt",
      "!dist/**/*",
      "!.git/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SimonRelays Player"
    }
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^2.1.8"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "ws": "^8.20.0"
  }
}
